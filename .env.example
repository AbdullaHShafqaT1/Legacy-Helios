# ==============================================================================
# Jarvis Phase 1 - Configuration Environment Variables (Example)
# ==============================================================================

# [REQUIRED] Anthropic API Key for Claude model access (e.g., sk-ant-...)
# Never commit actual credentials/keys to source control.
ANTHROPIC_API_KEY=

# Path to the SQLite relational database used for queueing and episodic memory.
# Default: memory-store/jarvis.db (automatically created if it doesn't exist)
JARVIS_DB_PATH=memory-store/jarvis.db

# The Anthropic model identifier to use for the orchestrator / agent cycles.
# Default: claude-sonnet-4-6
JARVIS_MODEL=claude-sonnet-4-6

# Maximum number of automatic retries on LLM or external service network failures.
# Default: 3
JARVIS_MAX_RETRIES=3

# The poll interval in milliseconds for the orchestrator task queue.
# Default: 5000 (5 seconds)
JARVIS_POLL_INTERVAL_MS=5000

# The timeout in milliseconds after which a running task is considered stale / timed out.
# Default: 300000 (5 minutes)
JARVIS_STALE_TASK_TIMEOUT_MS=300000

# Logging verbosity level (trace, debug, info, warn, error, fatal).
# Default: info
JARVIS_LOG_LEVEL=info
