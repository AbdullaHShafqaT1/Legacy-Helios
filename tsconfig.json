{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "sourceMap": true
  },
  "include": [
    "core/src/**/*",
    "core/test/**/*",
    "agents/**/*",
    "connectors/**/*",
    "cli/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
